<?xml version="1.0" ?>
<!--
  SmartNav World — Gazebo Sim Harmonic / ROS2
  ✅ Zéro fichier .dae externe requis
  ✅ 2 voitures dynamiques avec vitesse constante (VelocityControl)
  ✅ Design original 100% conservé
-->
<sdf version="1.9">
  <world name="smartnav_world">

    <!-- ==================== PLUGINS MONDE ==================== -->
    <plugin name="gz::sim::systems::Physics"          filename="gz-sim-physics-system"/>
    <plugin name="gz::sim::systems::UserCommands"     filename="gz-sim-user-commands-system"/>
    <plugin name="gz::sim::systems::SceneBroadcaster" filename="gz-sim-scene-broadcaster-system"/>
    <plugin name="gz::sim::systems::Sensors"          filename="gz-sim-sensors-system">
      <render_engine>ogre2</render_engine>
    </plugin>

    <!-- ==================== SCENE ==================== -->
    <scene>
      <ambient>0.90 0.90 0.90 1</ambient>
      <background>0.53 0.81 0.92 1</background>
      <shadows>true</shadows>
    </scene>

    <include>
      <uri>https://fuel.gazebosim.org/1.0/OpenRobotics/models/Sun</uri>
    </include>

    <!-- ================================================
         TERRAIN (herbe verte)
    ================================================ -->
    <model name="ground_grass">
      <static>true</static>
      <link name="link">
        <collision name="col">
          <geometry><plane><normal>0 0 1</normal><size>120 120</size></plane></geometry>
        </collision>
        <visual name="vis">
          <geometry><plane><normal>0 0 1</normal><size>120 120</size></plane></geometry>
          <material><ambient>0.18 0.40 0.12 1</ambient><diffuse>0.22 0.48 0.15 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- ================================================ ROUTES ================================================ -->
    <model name="road_main"><static>true</static><pose>0 0 0.02 0 0 0</pose><link name="link"><collision name="col"><geometry><box><size>60 8 0.04</size></box></geometry></collision><visual name="vis"><geometry><box><size>60 8 0.04</size></box></geometry><material><ambient>0.22 0.22 0.22 1</ambient><diffuse>0.28 0.28 0.28 1</diffuse></material></visual></link></model>
    <model name="road_cross"><static>true</static><pose>0 0 0.02 0 0 0</pose><link name="link"><collision name="col"><geometry><box><size>8 60 0.04</size></box></geometry></collision><visual name="vis"><geometry><box><size>8 60 0.04</size></box></geometry><material><ambient>0.22 0.22 0.22 1</ambient><diffuse>0.28 0.28 0.28 1</diffuse></material></visual></link></model>

    <!-- ================================================ TROTTOIRS ================================================ -->
    <model name="sidewalk_north"><static>true</static><pose>0 5 0.06 0 0 0</pose><link name="link"><collision name="col"><geometry><box><size>60 2 0.12</size></box></geometry></collision><visual name="vis"><geometry><box><size>60 2 0.12</size></box></geometry><material><ambient>0.73 0.73 0.71 1</ambient><diffuse>0.80 0.80 0.78 1</diffuse></material></visual></link></model>
    <model name="sidewalk_south"><static>true</static><pose>0 -5 0.06 0 0 0</pose><link name="link"><collision name="col"><geometry><box><size>60 2 0.12</size></box></geometry></collision><visual name="vis"><geometry><box><size>60 2 0.12</size></box></geometry><material><ambient>0.73 0.73 0.71 1</ambient><diffuse>0.80 0.80 0.78 1</diffuse></material></visual></link></model>
    <model name="sidewalk_east_S"><static>true</static><pose>5 -18 0.06 0 0 0</pose><link name="link"><collision name="col"><geometry><box><size>2 24 0.12</size></box></geometry></collision><visual name="vis"><geometry><box><size>2 24 0.12</size></box></geometry><material><ambient>0.73 0.73 0.71 1</ambient><diffuse>0.80 0.80 0.78 1</diffuse></material></visual></link></model>
    <model name="sidewalk_east_N"><static>true</static><pose>5 18 0.06 0 0 0</pose><link name="link"><collision name="col"><geometry><box><size>2 24 0.12</size></box></geometry></collision><visual name="vis"><geometry><box><size>2 24 0.12</size></box></geometry><material><ambient>0.73 0.73 0.71 1</ambient><diffuse>0.80 0.80 0.78 1</diffuse></material></visual></link></model>
    <model name="sidewalk_west_S"><static>true</static><pose>-5 -18 0.06 0 0 0</pose><link name="link"><collision name="col"><geometry><box><size>2 24 0.12</size></box></geometry></collision><visual name="vis"><geometry><box><size>2 24 0.12</size></box></geometry><material><ambient>0.73 0.73 0.71 1</ambient><diffuse>0.80 0.80 0.78 1</diffuse></material></visual></link></model>
    <model name="sidewalk_west_N"><static>true</static><pose>-5 18 0.06 0 0 0</pose><link name="link"><collision name="col"><geometry><box><size>2 24 0.12</size></box></geometry></collision><visual name="vis"><geometry><box><size>2 24 0.12</size></box></geometry><material><ambient>0.73 0.73 0.71 1</ambient><diffuse>0.80 0.80 0.78 1</diffuse></material></visual></link></model>

    <!-- ================================================ MARQUAGES ================================================ -->
    <model name="dm_w1"><static>true</static><pose>-26 0 0.05 0 0 0</pose><link name="l"><visual name="v"><geometry><box><size>2 0.15 0.01</size></box></geometry><material><ambient>1 1 1 1</ambient><diffuse>1 1 1 1</diffuse></material></visual></link></model>
